{
  "name": "playwright-pom-data-driven",
  "version": "1.0.0",
  "description": "Playwright TypeScript POM + Data-Driven Framework for AutomationExercise.com",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report",
    "allure:clean": "rimraf allure-results allure-report",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "setup:excel": "ts-node src/scripts/setupExcel.ts",
    "clean": "rimraf allure-results allure-report test-results"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.12.7",
    "allure-commandline": "^2.36.0",
    "allure-js-commons": "^3.0.0-beta.7",
    "allure-playwright": "^3.0.0-beta.7",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "playwright",
    "typescript",
    "pom",
    "data-driven",
    "allure"
  ],
  "author": "QA Team",
  "license": "MIT"
}
